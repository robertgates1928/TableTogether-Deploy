{
  "type": "module",
  "dependencies": {
    "@mojojs/core": "^1.26.10",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "htmx.org": "^2.0.8"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.0",
    "@types/node": "^22.5.0",
    "@types/stack-utils": "^2.0.1",
    "@types/tough-cookie": "^4.0.2",
    "@types/ws": "^8.5.3",
    "eslint": "^9.25.1",
    "nodemon": "^3.0.0",
    "npm-run-all2": "^7.0.2",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^38.0.0",
    "tap": "^21.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.31.1"
  },
  "scripts": {
    "build": "tsc --build ./",
    "build:test": "npm-run-all build test",
    "dev": "nodemon",
    "test": "tap --disable-coverage --allow-empty-coverage test/*.js test/*.ts",
    "seed": "npm run build && node lib/seed.js",
    "lint": "npm-run-all --continue-on-error lint:ts lint:css",
    "lint:fix": "npm-run-all --continue-on-error lint:ts:fix lint:css:fix",
    "lint:ts": "eslint",
    "lint:ts:fix": "eslint --fix",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint --fix \"**/*.css\"",
    "postinstall": "node -e \"const fs=require('fs');fs.mkdirSync('public/js',{recursive:true});fs.copyFileSync('node_modules/htmx.org/dist/htmx.min.js','public/js/htmx.min.js')\""
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "views"
    ],
    "ext": "ts,tmpl,css",
    "exec": "npm run build && node lib/index.js server"
  }
}
