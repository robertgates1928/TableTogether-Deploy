% view.layout = 'default';
% ctx.stash.title = "Upload Result"
<h2>Upload Result</h2>

<% if (ctx.stash.error) { %>
<p><strong>Error:</strong> <%= ctx.stash.error %></p>
<% } else if (ctx.stash.upload) { %>
<dl>
    <dt>Original filename</dt>
    <dd><%= ctx.stash.upload.fileName %></dd>
    <dt>Extension</dt>
    <dd><%= ctx.stash.upload.fileExt %></dd>
    <dt>Saved path</dt>
    <dd><%= ctx.stash.upload.savedPath %></dd>
</dl>
<p><a href="/<%= ctx.stash.upload.savedPath %>">View uploaded file</a></p>
<% } %>

<p><a href="/demo/upload">Upload another</a> | <a href="/">Back to home</a></p>
