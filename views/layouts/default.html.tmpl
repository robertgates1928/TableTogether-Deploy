<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= ctx.stash.title ?? 'TableTogether' %></title>
    <link rel="stylesheet" href="<%= ctx.urlForFile('styles.css') %>">
    <link rel="stylesheet" href="<%= ctx.urlForFile('bla-bla-anim.css') %>">
    <script src="<%= ctx.urlForFile('js/htmx.min.js') %>" defer></script>
</head>
<body>
    <header class="site-header">
        <div class="header-shell">
            <a class="brand" href="/">
                <span class="brand-mark">TT</span>
                <div>
                    <p class="brand-name">TableTogether</p>
                    <p class="brand-tagline">Restaurant meetup hub</p>
                </div>
            </a>
            <% if (ctx.isSessionActive) { %>
                <nav class="site-nav" aria-label="Primary">
                    <a href="/meetups/new">Create meetup</a>
                    <span>Signed in as <strong><%= ctx.stash.profileName %></strong></span>
                    <a href="/logout">Log out</a>
                </nav>
            <% } %>
        </div>
    </header>
    <main class="page-shell">
        <%= ctx.content.main %>
    </main>
    <footer class="site-footer">
        <p>Built for the BlaBla community hub brief using MojoJS, SQLite, and htmx.</p>
    </footer>
</body>
</html>
